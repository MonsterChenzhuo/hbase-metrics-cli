{
  "scenario": "rpc-latency",
  "cluster": "mrs-hbase-oline",
  "mode": "summary",
  "queries": [
    {
      "label": "p99",
      "expr": "topk(5, hadoop_hbase_processcalltime_99th_percentile{cluster=\"mrs-hbase-oline\", role=\"regionserver\", sub=\"IPC\"})\n"
    },
    {
      "label": "p999",
      "expr": "topk(5, hadoop_hbase_processcalltime_99_9th_percentile{cluster=\"mrs-hbase-oline\", role=\"regionserver\", sub=\"IPC\"})\n"
    }
  ],
  "columns": [
    "instance",
    "p99_max",
    "p99_avg",
    "p99_p99",
    "p99_last",
    "p999_max",
    "p999_avg",
    "p999_last"
  ],

{
  "scenario": "gc-pressure",
  "cluster": "mrs-hbase-oline",
  "mode": "summary",
  "queries": [
    {
      "label": "gc_count_per_min",
      "expr": "sum by (instance) (rate(jvm_gc_collectioncount{cluster=\"mrs-hbase-oline\", role=\"regionserver\"}[5m])) * 60\n"
    },
    {
      "label": "gc_time_ms_per_min",
      "expr": "sum by (instance) (rate(jvm_gc_collectiontime{cluster=\"mrs-hbase-oline\", role=\"regionserver\"}[5m])) * 60\n"
    }
  ],

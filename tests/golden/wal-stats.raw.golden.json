{
  "scenario": "wal-stats",
  "cluster": "mrs-hbase-oline",
  "mode": "raw",
  "queries": [
    {
      "label": "append_qps",
      "expr": "sum by (instance) (clamp_min(rate(hadoop_hbase_appendcount{cluster=\"mrs-hbase-oline\", role=\"regionserver\", sub=\"WAL\"}[5m]), 0))\n"
    },
    {
      "label": "sync_p99_ms",
      "expr": "hadoop_hbase_synctime_99th_percentile{cluster=\"mrs-hbase-oline\", role=\"regionserver\", sub=\"WAL\"}\n"
    },
    {
      "label": "slow_appends_per_min",
      "expr": "sum by (instance) (rate(hadoop_hbase_slowappendcount{cluster=\"mrs-hbase-oline\", role=\"regionserver\", sub=\"WAL\"}[5m])) * 60\n"
    }
  ],
  "columns": [
    "instance",
    "append_qps",
    "sync_p99_ms",
    "slow_appends_per_min"
  ],

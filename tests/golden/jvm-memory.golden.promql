# heap_used_mb
hadoop_hbase_memheapusedm{cluster="mrs-hbase-oline", role="regionserver"}

# heap_max_mb
hadoop_hbase_memheapmaxm{cluster="mrs-hbase-oline", role="regionserver"}

# heap_used_pct
100 * hadoop_hbase_memheapusedm{cluster="mrs-hbase-oline", role="regionserver"}
  / hadoop_hbase_memheapmaxm{cluster="mrs-hbase-oline", role="regionserver"}

